        "command(npx)",
        "command(pip)",
        "command(python)",
        "command(uv)",
        "command(vercel)",
        "command(yarn)",
        "command(docker)",
        "unsandboxed(curl)",
        "unsandboxed(firebase)",
        "unsandboxed(git)",
        "unsandboxed(node)",
        "unsandboxed(npm)",
        "unsandboxed(npx)",
        "unsandboxed(pip)",
        "unsandboxed(python)",
        "unsandboxed(uv)",
        "unsandboxed(vercel)",
        "unsandboxed(yarn)",
        "unsandboxed(docker)",
        "mcp(github-mcp-server/*)",
